rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{playerId} {
      allow read: if true;
      allow create, update: if request.resource.data.name is string
        && request.resource.data.group is string
        && request.resource.data.name.size() > 1
        && request.resource.data.group.size() > 0;
    }

    match /progress/{playerId} {
      allow read: if true;
      allow create, update: if request.resource.data.unlockedLevel is int
        && request.resource.data.bestScore is int;
    }

    match /leaderboard/{entryId} {
      allow read: if true;
      allow create: if request.resource.data.name is string
        && request.resource.data.group is string
        && request.resource.data.score is int
        && request.resource.data.levelReached is int;
      allow update: if false;
      allow delete: if false;
    }
  }
}
